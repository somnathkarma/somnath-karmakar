<style>
  .custom-hero {
    background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: {{ section.settings.text_color }};
    min-height: {{ section.settings.hero_height }}px;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    text-align: {{ section.settings.text_alignment }};
    position: relative;
    margin-bottom:40px;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 500px;
    padding-bottom: 70px;
    display: flex;
    flex-direction: column;
    align-items: {% if section.settings.text_alignment == 'center' %}center{% elsif section.settings.text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
  }


  .hero-heading {
    font-size: clamp(2rem, 5vw, 4.5rem);
    line-height: 1.2;
    margin-bottom: 0;
    font-weight: bold;
  }

  .hero-paragraph {
    font-size: clamp(1rem, 2vw, 1.2rem);
    margin-bottom: 30px;
    line-height: 1.6;
  }

  .hero-paragraph-mobile {
    display: none;
  }

  .note-paragraph{
    position: absolute;
    bottom: -40px;
    left: 0;
    right: 0;
    text-align: center;
    padding: 8px 30px;
    background-color: {{ section.settings.note_color }};
  }

  .note-paragraph-mobile{
    display: none;
  }

  @media (max-width: 768px) {
    .custom-hero {
        background-image: url('{{ section.settings.bg_mob_image | image_url: width: 2000 }}');
        background-size: 500px;
        background-position: bottom;
        background-repeat: repeat-x;
    }

    .hero-content{
        align-items: center;
        padding-bottom: 0;
        max-width: 100%;
        width: 100%;
    }

    .custom-hero {
      padding: 40px 0px;
      min-height: 420px;
      align-items: flex-start;
      text-align: center;
    }

    .note-paragraph{
        display: none;
    }

    .note-paragraph-mobile{
        position: absolute;
        bottom: -40px;
        left: 0;
        right: 0;
        text-align: center;
        padding: 8px 30px;
        background-color: {{ section.settings.note_color }};
        font-size: 14px;
        display: block;
    }

    .hero-paragraph {
        display: none;
    }

    .hero-paragraph-mobile {
        display: block;
        margin-bottom: 290px;
    }
  }
</style>

<section class="custom-hero">
  <div class="custom-container">
    <div class="hero-content">
      {% if section.settings.heading != blank %}
        <h1 class="hero-heading">{{ section.settings.heading }}</h1>
      {% endif %}

      {% if section.settings.paragraph != blank %}
        <p class="hero-paragraph">{{ section.settings.paragraph }}</p>
      {% endif %}
      {% if section.settings.paragraph_mobile != blank %}
        <p class="hero-paragraph-mobile">{{ section.settings.paragraph_mobile }}</p>
      {% endif %}

      {% if section.settings.button_label != blank %}
        {% render 'custom-button',
        text: section.settings.button_label,
        url: section.settings.button_link,
        btn_bg_color: section.settings.btn_bg_color,
        btn_bg_hover_color: section.settings.btn_bg_hover_color,
        btn_text_color: section.settings.btn_text_color,
        btn_hover_color: section.settings.btn_hover_color,
      %}
      {% endif %}
    </div>
  </div>
  {% if section.settings.note_paragraph != blank %}
    <p class="note-paragraph">{{ section.settings.note_paragraph }}</p>
  {% endif %}
  {% if section.settings.note_paragraph_mobile != blank %}
    <p class="note-paragraph-mobile">{{ section.settings.note_paragraph_mobile }}</p>
  {% endif %}
</section>

{% schema %}
{
  "name": "Custom Hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to Our Store"
    },
    {
      "type": "textarea",
      "id": "paragraph",
      "label": "Paragraph Desktop",
      "default": "Discover our latest collection of premium products designed for your lifestyle."
    },
    {
      "type": "textarea",
      "id": "paragraph_mobile",
      "label": "Paragraph Mobile",
      "default": "Discover our latest collection of premium products designed for your lifestyle."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "btn_bg_hover_color",
      "label": "Button Hover Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button Text Color",
    },
    {
      "type": "color",
      "id": "btn_hover_color",
      "label": "Button Text Hover Color",
    },
    {
      "type": "text",
      "id": "note_paragraph",
      "label": "Note",
      "default": "Discover our latest collection"
    },
    {
      "type": "text",
      "id": "note_paragraph_mobile",
      "label": "Note Mobile",
      "default": "Discover our latest collection"
    },
    {
      "type": "color",
      "id": "note_color",
      "label": "Note Background Color",
      "default": "#fff"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Desktop Background Image"
    },
    {
      "type": "image_picker",
      "id": "bg_mob_image",
      "label": "Mobile Background Image"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "hero_height",
      "min": 200,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Hero Min Height",
      "default": 400
    }
  ],
  "presets": [
    {
      "name": "Custom Hero"
    }
  ]
}
{% endschema %}
